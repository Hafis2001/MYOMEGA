{
  "expo": {
    "name": "MYOMEGA",
    "slug": "MYOMEGA",
    "version": "1.1.1",
    "orientation": "portrait",
    "icon": "./assets/images/custom-icon.png",
    "scheme": "myomega",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
  "supportsTablet": true,
  "buildNumber": "10",
  "infoPlist": {
    "NSLocationWhenInUseUsageDescription": "MYOMEGA needs your location to verify you are at the office when punching in or out.",
    "NSLocationAlwaysAndWhenInUseUsageDescription": "MYOMEGA needs your location to verify you are at the office when punching in or out.",
    "NSLocationTemporaryUsageDescriptionDictionary": {
      "PunchInAccuracy": "A precise location is needed to confirm you are within office premises."
    },
        "ITSAppUsesNonExemptEncryption": false
      },
      "bundleIdentifier": "com.imcbs.MYOMEGA"
    },
    "android": {
      "versionCode": 9,
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/custom-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "package": "com.hafis_riswan.MYOMEGA"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/custom-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/custom-splash.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1ac14247-da09-4aef-9861-3fb6d2af5e9d"
      }
    }
  }
}
